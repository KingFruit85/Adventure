{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm turbo run build --filter=@loreforge/web --filter=@loreforge/api --filter=@loreforge/engine",
  "outputDirectory": "packages/web/dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 300,
      "memory": 1024,
      "includeFiles": "adventures/**"
    }
  },
  "rewrites": [{ "source": "/api/:path*", "destination": "/api/index" }]
}
