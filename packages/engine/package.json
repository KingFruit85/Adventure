{
  "name": "@loreforge/engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adventures": {
      "types": "./dist/adventures/index.d.ts",
      "default": "./dist/adventures/index.js"
    },
    "./session-store": {
      "types": "./dist/session-store/index.d.ts",
      "default": "./dist/session-store/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loreforge/shared": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
